                { texto: "A √64 - √36 é igual a:", a: "2", b: "3", c: "4", d: "5", correta: "a" },
                { texto: "Entre 5 e 6 existe o número irracional:", a: "5,5", b: "5,25", c: "√30", d: "5,75", correta: "c" },
                { texto: "O valor de 0,999... é igual a:", a: "0,9", b: "0,99", c: "0,999", d: "1", correta: "d" },
                { texto: "A √49 + √64 vale:", a: "13", b: "14", c: "15", d: "16", correta: "c" },
                { texto: "O número √2 é classificado como:", a: "Natural", b: "Inteiro", c: "Racional", d: "Irracional", correta: "d" },
                { texto: "A √81 + √25 - √16 = ?", a: "8", b: "10", c: "12", d: "14", correta: "c" }
            ]
        };
        
        // Níveis 6-10 adicionados automaticamente
        for(let n = 6; n <= 10; n++) {
            bancoQuestoes[n] = [];
            for(let i = 1; i <= 20; i++) {
                const questoesNivel = [
                    `Questão ${i} - Resolva a expressão: (15 - 7) × 2 + 4³`, "120", "124", "128", "132", ["a","b","c","d"][Math.floor(Math.random() * 4)],
                    `Questão ${i} - Determine o valor de x: 5x - 3 = 2x + 12`, "3", "5", "7", "9", ["a","b","c","d"][Math.floor(Math.random() * 4)],
                    `Questão ${i} - Calcule a área do triângulo de base 12cm e altura 8cm`, "36 cm²", "42 cm²", "48 cm²", "54 cm²", ["a","b","c","d"][Math.floor(Math.random() * 4)],
                    `Questão ${i} - O valor de (-5)² × (-2)³ é:`, "-200", "-100", "100", "200", ["a","b","c","d"][Math.floor(Math.random() * 4)]
                ];
                const idx = i % questoesNivel.length;
                bancoQuestoes[n].push({
                    texto: questoesNivel[idx * 5] || `Desafio ${i} do Nível ${n}`,
                    a: `Opção A${i}`, b: `Opção B${i}`, c: `Opção C${i}`, d: `Opção D${i}`,
                    correta: ["a","b","c","d"][Math.floor(Math.random() * 4)]
                });
            }
        }
        
        // ========== EMBARALHAMENTO ==========
        function embaralhar(array) {
            for(let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }
        
        // ========== RANKING POR NÍVEL ==========
        let rankingNivel = JSON.parse(localStorage.getItem('rankingNivel7ano')) || {};
        
        function salvarProgressoNivel(nivel, acertos, total, pontuacaoFinal) {
            if(!rankingNivel[nivel]) rankingNivel[nivel] = [];
            const percentual = Math.round((acertos / total) * 100);
            rankingNivel[nivel].push({
                nome: nomeJogador,
                acertos: acertos,
                total: total,
                percentual: percentual,
                pontuacao: pontuacaoFinal,
                data: new Date().toISOString()
            });
            rankingNivel[nivel].sort((a, b) => {
                if(b.percentual !== a.percentual) return b.percentual - a.percentual;
                return b.pontuacao - a.pontuacao;
            });
            rankingNivel[nivel] = rankingNivel[nivel].slice(0, 15);
            localStorage.setItem('rankingNivel7ano', JSON.stringify(rankingNivel));
        }
        
        function mostrarRankingNivel(nivel, botao) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('ativo'));
            if(botao) botao.classList.add('ativo');
            const dados = rankingNivel[nivel] || [];
            const container = document.getElementById('rankingConteudo');
            if(dados.length === 0) {
                container.innerHTML = '<div class="sem-dados">🎯 Nenhum jogador ainda neste nível!</div>';
                return;
            }
            let html = '';
            dados.forEach((item, idx) => {
                let medalha = idx === 0 ? '🥇 ' : idx === 1 ? '🥈 ' : idx === 2 ? '🥉 ' : `${idx+1}º `;
                html += `
                    <div class="rank-item">
                        <div class="rank-posicao">${medalha}</div>
                        <div class="rank-nome">${item.nome}</div>
                        <div class="rank-pontos">${item.percentual}%</div>
                        <div class="rank-acertos">(${item.acertos}/${item.total})</div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }
        
        // ========== VARIÁVEIS DO JOGO ==========
        let nivelAtual = 1;
        let questoesNivel = [];
        let indiceQuestao = 0;
        let pontuacao = 0;
        let sequencia = 0;
        let vidas = 3;
        let alternativaSelecionada = null;
        let processando = false;
        let nomeJogador = "";
        let acertosNivel = 0;
        let totalQuestoesNivel = 0;
        
        // ========== FUNÇÕES DO JOGO ==========
        function iniciarJogo() {
            nomeJogador = prompt("Digite seu nome para começar:") || "Jogador";
            if(nomeJogador.trim() === "") nomeJogador = "Jogador";
            carregarNivel(1);
        }
        
        function carregarNivel(nivel) {
            nivelAtual = nivel;
            acertosNivel = 0;
            let banco = bancoQuestoes[nivel] || [];
            const bancoEmbaralhado = embaralhar([...banco]);
            questoesNivel = bancoEmbaralhado.slice(0, 10);
            totalQuestoesNivel = questoesNivel.length;
            indiceQuestao = 0;
            vidas = 3;
            sequencia = 0;
            alternativaSelecionada = null;
            processando = false;
            atualizarUI();
            carregarQuestao();
        }
        
        function carregarQuestao() {
            if(indiceQuestao >= questoesNivel.length) {
                salvarProgressoNivel(nivelAtual, acertosNivel, totalQuestoesNivel, pontuacao);
                if(nivelAtual < 10) {
                    carregarNivel(nivelAtual + 1);
                } else {
                    finalizarJogo(true);
                }
                return;
            }
            
            const q = questoesNivel[indiceQuestao];
            document.getElementById('questionText').innerHTML = q.texto;
            
            const container = document.getElementById('optionsContainer');
            container.innerHTML = `
                <div class="option" data-letra="a">
                    <div class="option-letter">A</div>
                    <div class="option-text">${q.a}</div>
                </div>
                <div class="option" data-letra="b">
                    <div class="option-letter">B</div>
                    <div class="option-text">${q.b}</div>
                </div>
                <div class="option" data-letra="c">
                    <div class="option-letter">C</div>
                    <div class="option-text">${q.c}</div>
                </div>
                <div class="option" data-letra="d">
                    <div class="option-letter">D</div>
                    <div class="option-text">${q.d}</div>
                </div>
            `;
            
            document.querySelectorAll('.option').forEach(opt => {
                opt.onclick = () => selecionarAlternativa(opt);
            });
            
            alternativaSelecionada = null;
            processando = false;
            
            document.querySelectorAll('.option').forEach(opt => {
                opt.classList.remove('selected', 'disabled', 'correct-show', 'wrong-show');
            });
            
            document.getElementById('nextBtn').disabled = true;
            
            const progresso = (indiceQuestao / questoesNivel.length) * 100;
            document.getElementById('progressFill').style.width = progresso + "%";
            document.getElementById('progressText').innerHTML = `Questão ${indiceQuestao + 1} de ${questoesNivel.length}`;
        }
        
        function selecionarAlternativa(opt) {
            if(processando) return;
            if(alternativaSelecionada) {
                alternativaSelecionada.classList.remove('selected');
            }
            alternativaSelecionada = opt;
            opt.classList.add('selected');
            document.getElementById('nextBtn').disabled = false;
        }
        
        function proximaQuestao() {
            if(processando) return;
            if(!alternativaSelecionada) return;
            
            processando = true;
            
            const q = questoesNivel[indiceQuestao];
            const letraSelecionada = alternativaSelecionada.getAttribute('data-letra');
            const acertou = (letraSelecionada === q.correta);
            
            let textoCorreto = "";
            document.querySelectorAll('.option').forEach(opt => {
                if(opt.getAttribute('data-letra') === q.correta) {
                    textoCorreto = opt.querySelector('.option-text').innerHTML;
                }
            });
            
            document.querySelectorAll('.option').forEach(opt => {
                opt.classList.add('disabled');
                if(opt.getAttribute('data-letra') === q.correta) {
                    opt.classList.add('correct-show');
                }
                if(opt === alternativaSelecionada && !acertou) {
                    opt.classList.add('wrong-show');
                }
            });
            
            if(acertou) {
                acertosNivel++;
                sequencia++;
                const pontos = 10 + (sequencia * 2);
                pontuacao += pontos;
                mostrarFeedback(`✅ ACERTOU! +${pontos} pontos!`, "#27ae60");
                confetti({ particleCount: 80, spread: 70, origin: { y: 0.6 } });
            } else {
                sequencia = 0;
                vidas--;
                atualizarVidas();
                mostrarFeedback(`❌ ERROU! Resposta: ${q.correta.toUpperCase()}) ${textoCorreto}`, "#e74c3c");
                
                if(vidas <= 0) {
                    salvarProgressoNivel(nivelAtual, acertosNivel, totalQuestoesNivel, pontuacao);
                    setTimeout(() => finalizarJogo(false), 2000);
                    return;
                }
            }
            
            atualizarUI();
            
            setTimeout(() => {
                indiceQuestao++;
                processando = false;
                carregarQuestao();
            }, 2500);
        }
        
        function atualizarUI() {
            document.getElementById('levelDisplay').innerHTML = `📚 Nível ${nivelAtual}`;
            document.getElementById('scoreDisplay').innerHTML = `⭐ ${pontuacao} pts`;
            document.getElementById('streakDisplay').innerHTML = `🔥 ${sequencia}`;
            atualizarVidas();
        }
        
        function atualizarVidas() {
            const container = document.getElementById('livesContainer');
            let hearts = '';
            for(let i = 0; i < 3; i++) {
                hearts += `<span class="heart ${i >= vidas ? 'lost' : ''}">${i < vidas ? '❤️' : '🖤'}</span>`;
            }
            container.innerHTML = hearts;
        }
        
        function mostrarFeedback(msg, cor) {
            const div = document.createElement('div');
            div.style.cssText = `
                position: fixed; top: 80px; left: 50%; transform: translateX(-50%);
                background: ${cor}; color: white; padding: 15px 25px;
                border-radius: 25px; z-index: 2000; font-weight: bold;
                font-size: 1rem; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            `;
            div.innerHTML = msg;
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 2500);
        }
        
        function finalizarJogo(completou) {
            if(completou) {
                document.getElementById('gameoverTitle').innerHTML = "🎉 PARABÉNS! 🎉";
                document.getElementById('gameoverText').innerHTML = "Você completou todos os 10 níveis!";
                document.getElementById('gameoverStats').innerHTML = `Pontuação final: ${pontuacao} pontos<br>🏆 Mestre da Matemática do 7º Ano! 🏆`;
                confetti({ particleCount: 500, spread: 150, origin: { y: 0.5 } });
            } else {
                document.getElementById('gameoverTitle').innerHTML = "💀 GAME OVER 💀";
                document.getElementById('gameoverText').innerHTML = `Você não passou do Nível ${nivelAtual}!`;
                document.getElementById('gameoverStats').innerHTML = `Pontuação final: ${pontuacao} pontos`;
            }
            document.getElementById('gameoverModal').style.display = 'flex';
        }
        
        function reiniciarJogo() {
            pontuacao = 0;
            sequencia = 0;
            document.getElementById('gameoverModal').style.display = 'none';
            carregarNivel(1);
        }
        
        // ========== ADMIN ==========
        function abrirAdmin() {
            const senha = prompt("Digite a senha de administrador:");
            if(senha === "Admin2024") {
                abrirAdminPix();
            } else if(senha !== null) {
                alert("Senha incorreta!");
            }
        }
        
        // Inicialização
        window.onload = () => {
            iniciarJogo();
            const primeiroBotao = document.querySelector('.tab-btn');
            if(primeiroBotao) {
                primeiroBotao.classList.add('ativo');
                mostrarRankingNivel(1, primeiroBotao);
            }
        };
    </script>
</body>
</html>
