<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Matemática 7º Ano - Jogo SAEB</title>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', 'Poppins', sans-serif;
            background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .pagina {
            max-width: 800px;
            margin: 0 auto;
        }
        
        .container {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }
        
        /* BOTÃO DE DOAÇÃO */
        .doacao-container {
            text-align: center;
            margin-bottom: 20px;
        }
        
        .btn-doar {
            background: linear-gradient(135deg, #f1c40f, #e67e22);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.3s, box-shadow 0.3s;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }
        
        .btn-doar:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 20px rgba(0,0,0,0.3);
        }
        
        /* ÁREA DO JOGO + RANKING */
        .game-area {
            flex: 1;
            min-width: 300px;
            max-width: 500px;
            margin: 0 auto;
        }
        
        /* CARD DO JOGO */
        .game-card {
            background: white;
            border-radius: 30px;
            padding: 25px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            text-align: center;
            margin-bottom: 20px;
        }
        
        .header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .badge {
            padding: 8px 15px;
            border-radius: 25px;
            font-weight: bold;
        }
        .badge-level { background: #2c3e50; color: white; }
        .badge-score { background: #f1c40f; color: #333; }
        .badge-streak { background: #e74c3c; color: white; }
        
        .progress-area { margin-bottom: 20px; }
        .progress-bar { width: 100%; height: 10px; background: #eee; border-radius: 10px; overflow: hidden; }
        .progress-fill { height: 100%; background: #27ae60; transition: width 0.5s; width: 0%; }
        .progress-text { font-size: 0.8rem; margin-top: 5px; color: #666; }
        
        .question-box {
            background: #f8f9fa;
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 20px;
        }
        
        .question-text {
            font-size: 1.2rem;
            color: #333;
            margin-bottom: 20px;
            font-weight: 600;
        }
        
        .options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .option {
            background: white;
            border: 2px solid #e0e0e0;
            border-radius: 15px;
            padding: 15px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 15px;
            transition: all 0.3s;
        }
        
        .option:hover { border-color: #3498db; transform: scale(1.02); }
        
        .option-letter {
            width: 40px;
            height: 40px;
            background: #2c3e50;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }
        
        .option-text { flex: 1; text-align: left; color: #333; }
        
        .option.selected {
            background: #3498db;
            border-color: #3498db;
        }
        .option.selected .option-text { color: white; }
        .option.selected .option-letter { background: white; color: #3498db; }
        
        .option.disabled {
            opacity: 0.7;
            cursor: not-allowed;
            pointer-events: none;
        }
        
        .option.correct-show {
            background: #27ae60;
            border-color: #27ae60;
        }
        .option.correct-show .option-text { color: white; }
        .option.correct-show .option-letter { background: white; color: #27ae60; }
        
        .option.wrong-show {
            background: #e74c3c;
            border-color: #e74c3c;
        }
        .option.wrong-show .option-text { color: white; }
        .option.wrong-show .option-letter { background: white; color: #e74c3c; }
        
        .lives {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin: 20px 0;
        }
        
        .heart { font-size: 1.8rem; }
        .heart.lost { opacity: 0.3; filter: grayscale(1); }
        
        button {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 15px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
            transition: transform 0.2s;
        }
        button:hover { transform: scale(0.98); }
        .btn-next { background: #27ae60; color: white; }
        .btn-next:disabled { opacity: 0.5; cursor: not-allowed; }
        .btn-restart { background: #3498db; color: white; }
        
        /* RANKING POR NÍVEL */
        .ranking-nivel {
            background: rgba(255,255,255,0.95);
            border-radius: 20px;
            padding: 20px;
            margin-top: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        
        .ranking-nivel h3 {
            color: #2c3e50;
            text-align: center;
            margin-bottom: 15px;
            font-size: 1.2rem;
        }
        
        .tabs-ranking {
            display: flex;
            gap: 5px;
            margin-bottom: 15px;
            flex-wrap: wrap;
            justify-content: center;
        }
        
        .tab-btn {
            background: #ecf0f1;
            border: none;
            padding: 8px 12px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s;
            margin-top: 0;
            width: auto;
        }
        
        .tab-btn:hover { transform: scale(1.05); background: #d5dbdb; }
        .tab-btn.ativo { background: #2c3e50; color: white; }
        
        .ranking-conteudo {
            max-height: 300px;
            overflow-y: auto;
        }
        
        .rank-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid #eee;
            transition: background 0.3s;
        }
        
        .rank-item:hover { background: #f8f9fa; }
        
        .rank-posicao {
            font-weight: bold;
            width: 45px;
            color: #2c3e50;
        }
        
        .rank-nome {
            flex: 2;
            font-weight: 600;
            color: #333;
        }
        
        .rank-pontos {
            font-weight: bold;
            color: #27ae60;
        }
        
        .rank-acertos {
            font-size: 0.8rem;
            color: #666;
            margin-left: 10px;
        }
        
        .sem-dados {
            text-align: center;
            color: #999;
            padding: 20px;
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        
        .modal-content {
            background: white;
            border-radius: 30px;
            padding: 30px;
            max-width: 400px;
            width: 90%;
            text-align: center;
        }
        
        .pix-area {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 15px;
            margin: 15px 0;
            word-break: break-all;
        }
        
        .pix-chave {
            font-family: monospace;
            font-size: 1rem;
            background: #e9ecef;
            padding: 10px;
            border-radius: 8px;
            margin: 10px 0;
        }
        
        .btn-copiar {
            background: #27ae60;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 10px;
        }
        
        .admin-form {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 15px;
        }
        
        .admin-form input, .admin-form select {
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 0.9rem;
        }
        
        footer {
            margin-top: 30px;
            text-align: center;
            color: rgba(255,255,255,0.6);
            font-size: 0.75rem;
            cursor: pointer;
            padding: 15px;
        }
        
        footer:hover {
            color: rgba(255,255,255,0.9);
        }
    </style>
</head>
<body>
    <div class="pagina">
        <!-- BOTÃO DE DOAÇÃO -->
        <div class="doacao-container">
            <button class="btn-doar" onclick="abrirDoacao()">
                💝 APOIAR PROJETO
            </button>
        </div>
        
        <div class="container">
            <!-- ÁREA DO JOGO + RANKING -->
            <div class="game-area">
                <!-- JOGO -->
                <div class="game-card">
                    <div class="header">
                        <div class="badge badge-level" id="levelDisplay">📚 Nível 1</div>
                        <div class="badge badge-score" id="scoreDisplay">⭐ 0 pts</div>
                        <div class="badge badge-streak" id="streakDisplay">🔥 0</div>
                    </div>
                    
                    <div class="progress-area">
                        <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
                        <div class="progress-text" id="progressText">Questão 1 de 10</div>
                    </div>
                    
                    <div class="lives" id="livesContainer">❤️ ❤️ ❤️</div>
                    
                    <div class="question-box">
                        <div class="question-text" id="questionText">Carregando...</div>
                        <div class="options" id="optionsContainer"></div>
                    </div>
                    
                    <button class="btn-next" id="nextBtn" onclick="proximaQuestao()" disabled>▶ PRÓXIMA</button>
                    <button class="btn-restart" onclick="reiniciarJogo()">🔄 RECOMEÇAR JOGO</button>
                </div>
                
                <!-- RANKING POR NÍVEL -->
                <div class="ranking-nivel">
                    <h3>🏆 RANKING POR NÍVEL 🏆</h3>
                    <div class="tabs-ranking">
                        <button class="tab-btn" onclick="mostrarRankingNivel(1, this)">Nível 1</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(2, this)">Nível 2</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(3, this)">Nível 3</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(4, this)">Nível 4</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(5, this)">Nível 5</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(6, this)">Nível 6</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(7, this)">Nível 7</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(8, this)">Nível 8</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(9, this)">Nível 9</button>
                        <button class="tab-btn" onclick="mostrarRankingNivel(10, this)">Nível 10</button>
                    </div>
                    <div class="ranking-conteudo" id="rankingConteudo">
                        <div class="sem-dados">🎯 Selecione um nível</div>
                    </div>
                </div>
            </div>
        </div>
        
        <footer onclick="abrirAdmin()">© 2026 | Configurações do Sistema</footer>
    </div>
    
    <!-- MODAL GAME OVER -->
    <div id="gameoverModal" class="modal">
        <div class="modal-content">
            <h2 id="gameoverTitle">🎉 PARABÉNS!</h2>
            <p id="gameoverText"></p>
            <p id="gameoverStats"></p>
            <button onclick="reiniciarJogo()">JOGAR NOVAMENTE</button>
        </div>
    </div>
    
    <!-- MODAL DOAÇÃO -->
    <div id="doacaoModal" class="modal">
        <div class="modal-content">
            <h2>💝 Apoie o Projeto</h2>
            <p>Sua contribuição ajuda a manter este jogo gratuito e em constante melhoria!</p>
            <div class="pix-area">
                <strong>📱 Chave PIX:</strong>
                <div class="pix-chave" id="pixChaveDisplay">carregando...</div>
                <button class="btn-copiar" onclick="copiarPix()">📋 Copiar Chave PIX</button>
            </div>
            <p style="font-size: 0.8rem; color: #666; margin-top: 10px;">Após a doação, o código será validado automaticamente.</p>
            <button onclick="fecharDoacao()" style="background: #666;">FECHAR</button>
        </div>
    </div>
    
    <!-- MODAL ADMIN PIX -->
    <div id="adminPixModal" class="modal">
        <div class="modal-content">
            <h2>🔧 Configurar Chave PIX</h2>
            <div class="admin-form">
                <label>Tipo da Chave:</label>
                <select id="pixTipo">
                    <option value="CPF">CPF</option>
                    <option value="CNPJ">CNPJ</option>
                    <option value="Email">E-mail</option>
                    <option value="Telefone">Telefone</option>
                    <option value="Aleatória">Chave Aleatória</option>
                </select>
                <label>Chave PIX:</label>
                <input type="text" id="pixChave" placeholder="Digite a chave PIX">
                <label>Nome do Beneficiário (opcional):</label>
                <input type="text" id="pixNome" placeholder="Nome do beneficiário">
                <button onclick="salvarPix()">💾 SALVAR CHAVE PIX</button>
                <button onclick="fecharAdminPix()" style="background:#666">FECHAR</button>
            </div>
        </div>
    </div>

    <script>
        // ========== CONFIGURAÇÃO PIX ==========
        let pixConfig = JSON.parse(localStorage.getItem('pixConfig7ano')) || {
            tipo: "Email",
            chave: "contato@matematica7ano.com",
            nome: "Projeto Matemática 7º Ano"
        };
        
        function salvarPix() {
            pixConfig = {
                tipo: document.getElementById('pixTipo').value,
                chave: document.getElementById('pixChave').value,
                nome: document.getElementById('pixNome').value
            };
            localStorage.setItem('pixConfig7ano', JSON.stringify(pixConfig));
            alert("Chave PIX salva com sucesso!");
            fecharAdminPix();
        }
        
        function abrirDoacao() {
            const chaveDisplay = document.getElementById('pixChaveDisplay');
            chaveDisplay.innerHTML = `${pixConfig.tipo}: ${pixConfig.chave}<br>${pixConfig.nome ? `(${pixConfig.nome})` : ''}`;
            document.getElementById('doacaoModal').style.display = 'flex';
        }
        
        function fecharDoacao() {
            document.getElementById('doacaoModal').style.display = 'none';
        }
        
        function copiarPix() {
            navigator.clipboard.writeText(pixConfig.chave);
            alert("Chave PIX copiada! ✅\n\n" + pixConfig.chave);
        }
        
        function abrirAdminPix() {
            document.getElementById('pixTipo').value = pixConfig.tipo;
            document.getElementById('pixChave').value = pixConfig.chave;
            document.getElementById('pixNome').value = pixConfig.nome || '';
            document.getElementById('adminPixModal').style.display = 'flex';
        }
        
        function fecharAdminPix() {
            document.getElementById('adminPixModal').style.display = 'none';
